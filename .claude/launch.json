{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "jerome-react",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "app", "run", "dev", "--", "--port", "5181", "--strictPort"],
      "port": 5181,
      "autoPort": false
